# NABH Compliance Engine - Backend Environment Variables

# DATABASE_URL: Your cloud database connection string.
# Recommended: Supabase (PostgreSQL) - Use Session Pooler URI for IPv4 support
# Example: postgres://postgres.xxx:password@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres
DATABASE_URL=your_postgresql_uri_here

# Allowed Origins for CORS (comma-separated list of frontend URLs)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: SQLite fallback path
DB_PATH=./nabh.db
